# Copy to terraform.tfvars (gitignored) and fill in subscription_id.
# subscription_id = "00000000-0000-0000-0000-000000000000"

# GitHub Actions: set repository variable AZURE_LOCATION (e.g. westeurope) to match
# Azure Policy "allowed locations"; if unset, CI uses the default in variables.tf.

# Optional overrides (default RG name is {project_name}-{environment}-rg, e.g. digitaltwin-dev-rg):
# resource_group_name       = "my-custom-rg"
# Example regions (slugs):
# location = "eastus"
# location = "westeurope"
# Default in variables.tf is eastus if you omit this.
# enable_azure_front_door   = false
# project_name              = "digitaltwin"
# environment               = "dev"

# If you purged a soft-deleted OpenAI account and want the fixed name back:
# openai_account_use_random_name_suffix = false

# OpenAI (defaults: gpt-4o-mini + Standard scale; deployment name gpt-4o for app compatibility):
# openai_deployment_name         = "gpt-4o"
# openai_model_name              = "gpt-4o-mini"
# openai_model_version           = "2024-08-06"
# openai_deployment_scale_type   = "Standard"
# openai_deployment_capacity      = 10
# For full gpt-4o when your subscription allows it:
# openai_model_name              = "gpt-4o"
# openai_model_version           = "2024-11-20"
# openai_deployment_scale_type   = "GlobalStandard"

# Functions: Y1 = consumption (default). B1 if you have Basic VM quota and need always_on:
# functions_service_plan_sku_name = "B1"

# openai_api_key is not required — Terraform creates OpenAI and outputs the key.
